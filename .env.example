# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# The app loads this file automatically on startup.
# Never commit .env — it is already in .gitignore.

# Required — used for embeddings (text-embedding-3-small) and all LLM calls
OPENAI_API_KEY=sk-...

# Optional — only needed if you want to run the notebooks directly
# LANGCHAIN_API_KEY=...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=AskMyBookmark
